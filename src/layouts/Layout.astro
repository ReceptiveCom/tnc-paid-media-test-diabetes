        <div class="tnc-footer-col">
          <div class="tnc-footer-heading">Find a dietitian by Insurance</div>
          <a href="/insurance/blue-cross-blue-shield">Blue Cross Blue Shield</a>
          <a href="/insurance/aetna">Aetna</a>
          <a href="/insurance/cigna">Cigna</a>
          <a href="/insurance/united-healthcare">United Healthcare</a>
          <a href="/insurance/anthem">Anthem</a>
          <a href="/insurance" class="tnc-footer-see-all">See All Insurance Plans</a>
        </div>
      </div>
      <div class="tnc-footer-bottom">
        <a href="https://www.topnutritioncoaching.com/" class="tnc-footer-logo">
          <img src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/6703d9fe64c092cc8093fd59_Logo%20TNC.svg" alt="Top Nutrition Coaching" style="height:35px;filter:brightness(0) invert(1);" />
        </a>
        <div class="tnc-footer-copyright">&copy; Copyright Top Nutrition Coaching 2026, Owned By Thrive Health Holdings Inc</div>
        <div class="tnc-footer-legal">
          <a href="/privacy-policy">Privacy policy</a> | <a href="/terms-of-use">Terms of use</a> | <a href="/html-sitemap">Sitemap</a>
        </div>
      </div>
    </footer>
    <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=626655ea8f0a3b341e18674a"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.e0c428ff9737f919.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.8f49cda2ca45c1d3.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.e34441d1.71befba8d22e80fd.js"></script>
  </body>
</html>
