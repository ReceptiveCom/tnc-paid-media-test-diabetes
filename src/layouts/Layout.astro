---
import WebflowNav from "../components/WebflowNav.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = "https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/6997459915eafeea166b5743_open-graph-img-landing-persona.avif",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}

    {/* Preconnect hints — match main TNC page */}
    <link rel="preconnect" href="https://cdn.prod.website-files.com" crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />

    {/* Favicons */}
    <link rel="shortcut icon" href="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/66deedec2fcd9c66d433c74b_32x32.png" type="image/x-icon" />
    <link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/66deede6990be7b723c9ba37_256x256.png" />

    {/* Webflow shared stylesheet */}
    <link href="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/css/top-nutrition-coaching-new-template.shared.726d6f8dd.css" rel="stylesheet" />

    {/* Webflow mod-js / mod-touch class detection (required by some Webflow shared CSS) */}
    <script is:inline>
      !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
    </script>

    {/* Custom TNC site script (loads OptiMonk handlers, custom event tracking, etc.) */}
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var host = window.location.hostname;
        var isStaging = host === "top-nutrition-coaching-new-template.webflow.io";
        var s = document.createElement("script");
        s.type = "module";
        s.src = isStaging
          ? "https://thrive-mvp-assets.s3.amazonaws.com/staging/js/script.js"
          : "https://assets.topnutritioncoaching.com/prod/js/script.js";
        document.head.appendChild(s);
      });
    </script>

    {/* Webflow init queue (works whether jQuery is loaded yet or not) */}
    <script is:inline>
      var Webflow = Webflow || [];
      Webflow.push(function() { $('html').addClass('webflow-loaded') });
    </script>

    {/* Stape server-side GTM bootstrap — GTM-M4NTBQN via vmats.topnutritioncoaching.com */}
    <script is:inline>
      !function(){"use strict";function l(e){for(var t=e,r=0,n=document.cookie.split(";");r<n.length;r++){var o=n[r].split("=");if(o[0].trim()===t)return o[1]}}function s(e){return localStorage.getItem(e)}function u(e){return window[e]}function A(e,t){e=document.querySelector(e);return t?null==e?void 0:e.getAttribute(t):null==e?void 0:e.textContent}var e=window,t=document,r="script",n="dataLayer",o="https://vmats.topnutritioncoaching.com",a="https://load.vmats.topnutritioncoaching.com",i="8od72degcuxin",c="8=aWQ9R1RNLU00TlRCUU4%3D&page=2",g="cookie",v="tnc_user_cookie",E="",d=!1;try{var d=!!g&&(m=navigator.userAgent,!!(m=new RegExp("Version/([0-9._]+)(.*Mobile)?.*Safari.*").exec(m)))&&16.4<=parseFloat(m[1]),f="stapeUserId"===g,I=d&&!f?function(e,t,r){void 0===t&&(t="");var n={cookie:l,localStorage:s,jsVariable:u,cssSelector:A},t=Array.isArray(t)?t:[t];if(e&&n[e])for(var o=n[e],a=0,i=t;a<i.length;a++){var c=i[a],c=r?o(c,r):o(c);if(c)return c}else console.warn("invalid uid source",e)}(g,v,E):void 0;d=d&&(!!I||f)}catch(e){console.error(e)}var m=e,g=(m[n]=m[n]||[],m[n].push({"gtm.start":(new Date).getTime(),event:"gtm.js"}),t.getElementsByTagName(r)[0]),v=I?"&bi="+encodeURIComponent(I):"",E=t.createElement(r),f=(d&&(i=8<i.length?i.replace(/([a-z]{8}$)/,"kp$1"):"kp"+i),!d&&a?a:o);E.async=!0,E.src=f+"/"+i+".js?"+c+v,null!=(e=g.parentNode)&&e.insertBefore(E,g)}();
    </script>

    {/* Ahrefs site analytics */}
    <script is:inline async src="https://analytics.ahrefs.com/analytics.js"></script>

    {/* Convert.com A/B testing — required for paid LP experiments */}
    <script is:inline>
      var _conv_page_type = "";
      var _conv_category_id = "";
      var _conv_category_name = "";
      var _conv_product_sku = "";
      var _conv_product_name = "";
      var _conv_product_price = "";
      var _conv_customer_id = "";
      var _conv_custom_v1 = "";
      var _conv_custom_v2 = "";
      var _conv_custom_v3 = "";
      var _conv_custom_v4 = "";
    </script>
    <script is:inline src="//cdn-4.convertexperiments.com/v1/js/10041372-10042361.js?environment=production"></script>

    <slot name="head" />
    <style is:inline>
      main { margin-top: 82px; }
    </style>
  </head>
  <body>
    {/* GTM noscript fallback (Stape proxy) */}
    <noscript><iframe src="https://load.vmats.topnutritioncoaching.com/ns.html?id=GTM-M4NTBQN" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <WebflowNav />
    <main>
      <slot />
    </main>
    <slot name="after-main" />
    <footer class="tnc-footer">
      <div class="tnc-footer-bottom">
        <a href="https://www.topnutritioncoaching.com/" class="tnc-footer-logo">
          <img src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/6703d9fe64c092cc8093fd59_Logo%20TNC.svg" alt="Top Nutrition Coaching" style="height:35px;filter:brightness(0) invert(1);" />
        </a>
        <div class="tnc-footer-copyright">&copy; Copyright Top Nutrition Coaching 2026, Owned By Thrive Health Holdings Inc</div>
        <div class="tnc-footer-legal">
          <a href="/privacy-policy">Privacy policy</a> | <a href="/terms-of-use">Terms of use</a> | <a href="/html-sitemap">Sitemap</a>
        </div>
      </div>
    </footer>

    {/* Schema.org Product + AggregateRating (matches main TNC page's pattern) */}
    <script is:inline>
      window.aggregateRating = {
        ratingValue: "4.9",
        bestRating: "5",
        worstRating: "3",
        ratingCount: "80"
      };
    </script>
    <script is:inline>
      (function () {
        const description = document.querySelector('meta[name="description"]')?.content || "";
        const name = document.querySelector('title')?.textContent || "Top Nutrition Coaching";
        const image = document.querySelector('meta[property="og:image"]')?.content || "";
        const data = {
          "@context": "https://schema.org/",
          "@type": "Product",
          name,
          image,
          description,
          brand: { "@type": "Brand", name: "Top Nutrition Coaching" },
          aggregateRating: { "@type": "AggregateRating", ...window.aggregateRating }
        };
        var s = document.createElement("script");
        s.type = "application/ld+json";
        s.innerHTML = JSON.stringify(data);
        document.head.appendChild(s);
      })();
    </script>

    <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=626655ea8f0a3b341e18674a"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.e0c428ff9737f919.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.8f49cda2ca45c1d3.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.e34441d1.71befba8d22e80fd.js"></script>

    {/* Zendesk Web Widget — defer until first interaction or 4s, whichever first */}
    <script is:inline>
      (function () {
        var loaded = false;
        function loadZendesk() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement("script");
          s.id = "ze-snippet";
          s.src = "https://static.zdassets.com/ekr/snippet.js?key=460c18ee-0595-46ad-8026-0ee2fb07d01a";
          document.body.appendChild(s);
        }
        setTimeout(loadZendesk, 4000);
        ["mousemove", "scroll", "keydown", "touchstart"].forEach(function (evt) {
          window.addEventListener(evt, loadZendesk, { once: true, passive: true });
        });
      })();
    </script>
  </body>
</html>
