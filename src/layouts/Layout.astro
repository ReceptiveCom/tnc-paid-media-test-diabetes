---
import WebflowNav from "../components/WebflowNav.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link href="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/css/top-nutrition-coaching-new-template.shared.726d6f8dd.css" rel="stylesheet" />
    <slot name="head" />
    <style is:inline>
      main { margin-top: 82px; }
    </style>
  </head>
  <body>
    <WebflowNav />
    <main>
      <slot />
    </main>
    <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=626655ea8f0a3b341e18674a"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.e0c428ff9737f919.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.schunk.8f49cda2ca45c1d3.js"></script>
    <script is:inline src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/js/top-nutrition-coaching-new-template.e34441d1.71befba8d22e80fd.js"></script>
  </body>
</html>
